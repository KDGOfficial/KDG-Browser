{
  "name": "kdg-browser",
  "version": "3.1.0",
  "description": "KDG Browser - Chromium-based browser with AI features for KDG Channel",
  "author": "KDG Developer",
  "main": "dist-electron/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc --noEmit && vite build && node scripts/build-main.js",
    "build:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.kdg.browser",
    "productName": "KDG Browser",
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "KDGOfficial",
        "repo": "KDG-Browser"
      }
    ]
  }
}
