{
  "name": "kdg-browser",
  "version": "4.0.0-alpha.1",
  "description": "Custom high-performance web browser focused on gaming and custom Web Store extensions",
  "author": "KDG Developer",
  "main": "dist-electron/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc --noEmit && vite build && node scripts/build-main.js",
    "build:win": "npm run build && electron-builder --win",
    "publish:win": "npm run build && electron-builder --win -p always"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "@google/generative-ai": "^0.21.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.3.0",
    "cross-fetch": "^4.1.0",
    "electron-chrome-extensions": "^4.9.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.1",
    "javascript-obfuscator": "^5.4.3",
    "terser": "^5.48.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  },
  "build": {
    "appId": "com.kdg.browser",
    "productName": "KDG Browser",
    "asar": true,
    "protocols": [
      {
        "name": "KDG Protocol",
        "schemes": [
          "kdg"
        ]
      }
    ],
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/adm-zip/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "KDGOfficial",
        "repo": "KDG-Browser",
        "releaseType": "release"
      }
    ]
  }
}